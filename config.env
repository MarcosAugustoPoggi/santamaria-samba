# Configuração Samba - Santa Maria
# Customize aqui se precisar mudar servidor/credenciais

# Servidor Samba
SAMBA_SERVER=192.168.15.212
SAMBA_SHARE=santamaria

# Credenciais
SAMBA_USER=santamaria
SAMBA_PASS=santamaria

# Montagem
MOUNT_POINT=/mnt/santamaria
USER_LINK=~/santamaria

# Timeouts e retries
RETRY_DELAY=5              # Segundos entre tentativas
MAX_RETRIES=30             # Max tentativas (30 * 5s = 150s total)
